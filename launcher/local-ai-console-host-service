#!/bin/bash
set -euo pipefail

ACTION="${1:-reload}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CODEX_HOME="${CODEX_HOME:-$HOME/.codex-local-desktop}"
CONFIG_PATH="${CODEX_HOME}/config.toml"
XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
STATE_DIR="${XDG_STATE_HOME}/local-ai-console-host"
CACHE_DIR="${XDG_CACHE_HOME}/local-ai-console"
PID_FILE="${STATE_DIR}/app-server.pid"
SERVE_PORT_FILE="${STATE_DIR}/tailscale-https-port"
LOG_FILE="${CACHE_DIR}/host-service.log"
CODEX_HELPER="${LOCAL_LLM_CONSOLE_CODEX_HELPER:-$REPO_ROOT/launcher/local-ai-console-codex}"

mkdir -p "$STATE_DIR" "$CACHE_DIR"

normalize_local_llm_console_config() {
  python3 - "$CONFIG_PATH" <<'PY'
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
if not path.is_file():
    raise SystemExit(0)

text = path.read_text(encoding="utf-8")

def normalize_provider(value: str) -> str:
    value = (value or "").strip().lower()
    if value in {"codex", "openai"}:
        return "codex"
    if value in {"remote", "local_llm_console_remote"}:
        return "remote"
    if value == "lmstudio":
        return "lmstudio"
    return "ollama"


model_match = re.search(r'(?m)^\s*model_provider\s*=\s*"([^"]*)"', text)
oss_match = re.search(r'(?m)^\s*oss_provider\s*=\s*"([^"]*)"', text)
model_value_match = re.search(r'(?m)^\s*model\s*=\s*"([^"]*)"', text)
catalog_match = re.search(r'(?m)^\s*model_catalog_json\s*=\s*"([^"]*)"', text)
alias_matches = re.findall(r'(?m)^\s*local_llm_console_provider\s*=\s*"([^"]*)"', text)

provider = normalize_provider(
    alias_matches[-1]
    if alias_matches
    else (
        model_match.group(1)
        if model_match
        else (oss_match.group(1) if oss_match else "ollama")
    )
)

catalog_value = (catalog_match.group(1).strip() if catalog_match else "")
if not catalog_value and provider not in {"codex", "remote"}:
    parent = path.parent.parent
    suffix = path.parent.name
    catalog_value = str(parent / f"{suffix}-models.json")

if provider not in {"codex", "remote"} and (not catalog_value or not Path(catalog_value).is_file()):
    provider = "codex"
    catalog_value = ""

model_value = model_value_match.group(1).strip() if model_value_match else ""
if provider == "codex" and (not model_value or ":" in model_value):
    model_value = "gpt-5.4"

runtime_provider = (
    "openai"
    if provider == "codex"
    else ("local_llm_console_remote" if provider == "remote" else provider)
)

lines = text.splitlines()
normalized = []
have_model_provider = False
have_oss_provider = False
have_model_catalog = False
have_model = False

for line in lines:
    if re.match(r'^\s*local_llm_console_provider\s*=.*$', line):
        continue
    if re.match(r'^\s*model_provider\s*=.*$', line):
        normalized.append(f'model_provider = "{runtime_provider}"')
        have_model_provider = True
        continue
    if re.match(r'^\s*oss_provider\s*=.*$', line):
        normalized.append(f'oss_provider = "{runtime_provider}"')
        have_oss_provider = True
        continue
    if re.match(r'^\s*model\s*=.*$', line):
        normalized.append(f'model = "{model_value}"')
        have_model = True
        continue
    if re.match(r'^\s*model_catalog_json\s*=.*$', line):
        if provider not in {"codex", "remote"}:
            normalized.append(f'model_catalog_json = "{catalog_value}"')
            have_model_catalog = True
        continue
    normalized.append(line)

if not have_model_provider:
    normalized.insert(0, f'model_provider = "{runtime_provider}"')
if not have_oss_provider:
    insert_at = 1 if normalized and normalized[0].startswith("model_provider = ") else 0
    normalized.insert(insert_at, f'oss_provider = "{runtime_provider}"')
if not have_model:
    insert_at = 0
    for index, line in enumerate(normalized):
        if line.startswith("oss_provider = ") or line.startswith("model_provider = "):
            insert_at = index + 1
    normalized.insert(insert_at, f'model = "{model_value or "gpt-5.4"}"')
if provider not in {"codex", "remote"} and not have_model_catalog:
    insert_at = 0
    for index, line in enumerate(normalized):
        if line.startswith("model_reasoning_effort = ") or line.startswith("model = "):
            insert_at = index + 1
    normalized.insert(insert_at, f'model_catalog_json = "{catalog_value}"')

top_level_insert_at = next(
    (index for index, line in enumerate(normalized) if line.startswith("[")),
    len(normalized),
)
normalized.insert(top_level_insert_at, f'local_llm_console_provider = "{provider}"')

new_text = "\n".join(normalized).rstrip() + "\n"
if new_text != text:
    path.write_text(new_text, encoding="utf-8")
PY
}

normalize_local_llm_console_config

LOCAL_LLM_CONSOLE_HOST_CONFIG="$(
  python3 - "$CONFIG_PATH" <<'PY'
from pathlib import Path
import re
import sys
from urllib.parse import urlparse

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8") if path.is_file() else ""


def read_string(key, default=""):
    match = re.search(rf'(?m)^\s*{re.escape(key)}\s*=\s*"([^"]*)"', text)
    return match.group(1) if match else default


def read_value(key, default=None):
    match = re.search(rf'(?m)^\s*{re.escape(key)}\s*=\s*([^\n#]+)', text)
    if not match:
        return default
    raw = match.group(1).strip()
    if raw.startswith('"') and raw.endswith('"') and len(raw) >= 2:
        return raw[1:-1]
    lowered = raw.lower()
    if lowered in {"true", "false"}:
        return lowered == "true"
    try:
        return int(raw)
    except ValueError:
        return raw


def clean_string(value, default=""):
    if not isinstance(value, str):
        return default
    value = value.strip()
    return value or default


def clean_identifier(value, default):
    value = clean_string(value, default)
    allowed = set("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789._:-")
    return value if value and set(value) <= allowed else default


def clean_bool(value):
    return value is True or value == "true" or value == "on"


def clean_port(value, default=443):
    if isinstance(value, int) and value > 0:
        return value
    if isinstance(value, str) and value.strip().isdigit():
        parsed = int(value.strip())
        if parsed > 0:
            return parsed
    return default


def normalize_ws_url(value, default):
    value = clean_string(value, default)
    if "://" not in value:
        value = f"ws://{value}"
    parsed = urlparse(value)
    if parsed.scheme not in {"ws", "wss"}:
        return default
    if not parsed.hostname:
        return default
    return parsed.geturl()


provider = clean_identifier(
    read_string("local_llm_console_provider")
    or read_string("model_provider")
    or read_string("oss_provider"),
    "codex",
)
host_enabled = clean_bool(read_value("local_llm_console_host_enabled"))
host_transport = clean_string(read_value("local_llm_console_host_transport"), "tailscale")
host_listen_url = normalize_ws_url(
    read_value("local_llm_console_host_listen_url"),
    "ws://127.0.0.1:8765",
)
host_https_port = clean_port(read_value("local_llm_console_host_https_port"), 443)

parsed = urlparse(host_listen_url)
proxy_host = parsed.hostname or "127.0.0.1"
proxy_port = parsed.port or 8765

print("on" if host_enabled else "off")
print(provider)
print(host_transport)
print(host_listen_url)
print(str(host_https_port))
print(proxy_host)
print(str(proxy_port))
PY
)"

HOST_ENABLED="$(printf '%s\n' "$LOCAL_LLM_CONSOLE_HOST_CONFIG" | sed -n '1p')"
LOCAL_PROVIDER="$(printf '%s\n' "$LOCAL_LLM_CONSOLE_HOST_CONFIG" | sed -n '2p')"
HOST_TRANSPORT="$(printf '%s\n' "$LOCAL_LLM_CONSOLE_HOST_CONFIG" | sed -n '3p')"
HOST_LISTEN_URL="$(printf '%s\n' "$LOCAL_LLM_CONSOLE_HOST_CONFIG" | sed -n '4p')"
HOST_HTTPS_PORT="$(printf '%s\n' "$LOCAL_LLM_CONSOLE_HOST_CONFIG" | sed -n '5p')"
HOST_PROXY_HOST="$(printf '%s\n' "$LOCAL_LLM_CONSOLE_HOST_CONFIG" | sed -n '6p')"
HOST_PROXY_PORT="$(printf '%s\n' "$LOCAL_LLM_CONSOLE_HOST_CONFIG" | sed -n '7p')"

HOST_ENABLED="${HOST_ENABLED:-off}"
LOCAL_PROVIDER="${LOCAL_PROVIDER:-codex}"
HOST_TRANSPORT="${HOST_TRANSPORT:-tailscale}"
HOST_LISTEN_URL="${HOST_LISTEN_URL:-ws://127.0.0.1:8765}"
HOST_HTTPS_PORT="${HOST_HTTPS_PORT:-443}"
HOST_PROXY_HOST="${HOST_PROXY_HOST:-127.0.0.1}"
HOST_PROXY_PORT="${HOST_PROXY_PORT:-8765}"

log() {
  printf '[%s] %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$*" >>"$LOG_FILE"
}

pid_is_alive() {
  local pid="$1"
  [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1
}

read_existing_pid() {
  if [[ -f "$PID_FILE" ]]; then
    cat "$PID_FILE" 2>/dev/null || true
  fi
}

stop_app_server() {
  local existing_pid
  existing_pid="$(read_existing_pid)"

  if ! pid_is_alive "$existing_pid"; then
    rm -f "$PID_FILE"
    return 0
  fi

  log "stopping codex app-server pid=${existing_pid}"
  kill "$existing_pid" >/dev/null 2>&1 || true
  sleep 0.5

  if pid_is_alive "$existing_pid"; then
    kill -9 "$existing_pid" >/dev/null 2>&1 || true
    sleep 0.2
  fi

  rm -f "$PID_FILE"
}

clear_tailscale_publish() {
  if [[ "$HOST_TRANSPORT" != "tailscale" ]]; then
    rm -f "$SERVE_PORT_FILE"
    return 0
  fi

  if ! command -v tailscale >/dev/null 2>&1; then
    rm -f "$SERVE_PORT_FILE"
    return 0
  fi

  local saved_port=""
  if [[ -f "$SERVE_PORT_FILE" ]]; then
    saved_port="$(cat "$SERVE_PORT_FILE" 2>/dev/null || true)"
  fi

  local ports=()
  if [[ -n "$saved_port" ]]; then
    ports+=("$saved_port")
  fi
  if [[ -n "$HOST_HTTPS_PORT" && "$HOST_HTTPS_PORT" != "$saved_port" ]]; then
    ports+=("$HOST_HTTPS_PORT")
  fi

  local port=""
  for port in "${ports[@]}"; do
    log "clearing tailscale serve https=${port}"
    if command -v timeout >/dev/null 2>&1; then
      timeout 4s tailscale serve --https="$port" off >>"$LOG_FILE" 2>&1 || log "tailscale serve clear failed or timed out for https=${port}"
    else
      tailscale serve --https="$port" off >>"$LOG_FILE" 2>&1 || log "tailscale serve clear failed for https=${port}"
    fi
  done

  rm -f "$SERVE_PORT_FILE"
}

start_app_server() {
  local existing_pid
  existing_pid="$(read_existing_pid)"

  if pid_is_alive "$existing_pid"; then
    log "app-server already running pid=${existing_pid}"
    return 0
  fi

  if [[ ! -x "$CODEX_HELPER" ]]; then
    log "bundled codex helper missing at $CODEX_HELPER"
    return 1
  fi

  log "starting codex app-server listen=${HOST_LISTEN_URL} provider=${LOCAL_PROVIDER}"
  nohup "$CODEX_HELPER" \
    app-server \
    --disable plugins \
    --listen "$HOST_LISTEN_URL" \
    >>"$LOG_FILE" 2>&1 </dev/null &
  echo "$!" >"$PID_FILE"
}

ensure_tailscale_publish() {
  if [[ "$HOST_TRANSPORT" != "tailscale" ]]; then
    rm -f "$SERVE_PORT_FILE"
    return 0
  fi

  if command -v tailscale >/dev/null 2>&1; then
    log "ensuring tailscale serve https=${HOST_HTTPS_PORT} target=http://${HOST_PROXY_HOST}:${HOST_PROXY_PORT}"
    if command -v timeout >/dev/null 2>&1; then
      timeout 4s tailscale serve --bg --https="$HOST_HTTPS_PORT" "http://${HOST_PROXY_HOST}:${HOST_PROXY_PORT}" >>"$LOG_FILE" 2>&1 || log "tailscale serve failed or timed out"
    else
      tailscale serve --bg --https="$HOST_HTTPS_PORT" "http://${HOST_PROXY_HOST}:${HOST_PROXY_PORT}" >>"$LOG_FILE" 2>&1 || log "tailscale serve failed"
    fi
    printf '%s\n' "$HOST_HTTPS_PORT" >"$SERVE_PORT_FILE"
  else
    log "tailscale CLI not found; skipping tailscale serve publish step"
  fi
}

case "$ACTION" in
  start)
    if [[ "$HOST_ENABLED" != "on" ]]; then
      log "host mode disabled; skipping start"
      exit 0
    fi
    start_app_server
    ensure_tailscale_publish
    ;;
  stop)
    stop_app_server
    clear_tailscale_publish
    ;;
  reload)
    stop_app_server
    clear_tailscale_publish
    if [[ "$HOST_ENABLED" != "on" ]]; then
      log "host mode disabled; reload completed with host service stopped"
      exit 0
    fi
    start_app_server
    ensure_tailscale_publish
    ;;
  *)
    echo "Unknown action: $ACTION" >&2
    exit 1
    ;;
esac
