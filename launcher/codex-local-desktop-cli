#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CODEX_HOME="${CODEX_HOME:-$HOME/.codex-local-desktop}"
CONFIG_PATH="${CODEX_HOME}/config.toml"
CODEX_HELPER="${LOCAL_LLM_CONSOLE_CODEX_HELPER:-$SCRIPT_DIR/local-ai-console-codex}"

normalize_local_llm_console_config() {
  python3 - "$CONFIG_PATH" <<'PY'
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
if not path.is_file():
    raise SystemExit(0)

text = path.read_text(encoding="utf-8")

def normalize_provider(value: str) -> str:
    value = (value or "").strip().lower()
    if value in {"codex", "openai"}:
        return "codex"
    if value in {"remote", "local_llm_console_remote"}:
        return "remote"
    if value == "lmstudio":
        return "lmstudio"
    return "ollama"


model_match = re.search(r'(?m)^\s*model_provider\s*=\s*"([^"]*)"', text)
oss_match = re.search(r'(?m)^\s*oss_provider\s*=\s*"([^"]*)"', text)
model_value_match = re.search(r'(?m)^\s*model\s*=\s*"([^"]*)"', text)
catalog_match = re.search(r'(?m)^\s*model_catalog_json\s*=\s*"([^"]*)"', text)
alias_matches = re.findall(r'(?m)^\s*local_llm_console_provider\s*=\s*"([^"]*)"', text)

provider = normalize_provider(
    alias_matches[-1]
    if alias_matches
    else (
        model_match.group(1)
        if model_match
        else (oss_match.group(1) if oss_match else "ollama")
    )
)

catalog_value = (catalog_match.group(1).strip() if catalog_match else "")
if not catalog_value and provider not in {"codex", "remote"}:
    parent = path.parent.parent
    suffix = path.parent.name
    catalog_value = str(parent / f"{suffix}-models.json")

if provider not in {"codex", "remote"} and (not catalog_value or not Path(catalog_value).is_file()):
    provider = "codex"
    catalog_value = ""

model_value = model_value_match.group(1).strip() if model_value_match else ""
if provider == "codex" and (not model_value or ":" in model_value):
    model_value = "gpt-5.4"

runtime_provider = (
    "openai"
    if provider == "codex"
    else ("local_llm_console_remote" if provider == "remote" else provider)
)

lines = text.splitlines()
normalized = []
have_model_provider = False
have_oss_provider = False
have_model_catalog = False
have_model = False

for line in lines:
    if re.match(r'^\s*local_llm_console_provider\s*=.*$', line):
        continue
    if re.match(r'^\s*model_provider\s*=.*$', line):
        normalized.append(f'model_provider = "{runtime_provider}"')
        have_model_provider = True
        continue
    if re.match(r'^\s*oss_provider\s*=.*$', line):
        normalized.append(f'oss_provider = "{runtime_provider}"')
        have_oss_provider = True
        continue
    if re.match(r'^\s*model\s*=.*$', line):
        normalized.append(f'model = "{model_value}"')
        have_model = True
        continue
    if re.match(r'^\s*model_catalog_json\s*=.*$', line):
        if provider not in {"codex", "remote"}:
            normalized.append(f'model_catalog_json = "{catalog_value}"')
            have_model_catalog = True
        continue
    normalized.append(line)

if not have_model_provider:
    normalized.insert(0, f'model_provider = "{runtime_provider}"')
if not have_oss_provider:
    insert_at = 1 if normalized and normalized[0].startswith("model_provider = ") else 0
    normalized.insert(insert_at, f'oss_provider = "{runtime_provider}"')
if not have_model:
    insert_at = 0
    for index, line in enumerate(normalized):
        if line.startswith("oss_provider = ") or line.startswith("model_provider = "):
            insert_at = index + 1
    normalized.insert(insert_at, f'model = "{model_value or "gpt-5.4"}"')
if provider not in {"codex", "remote"} and not have_model_catalog:
    insert_at = 0
    for index, line in enumerate(normalized):
        if line.startswith("model_reasoning_effort = ") or line.startswith("model = "):
            insert_at = index + 1
    normalized.insert(insert_at, f'model_catalog_json = "{catalog_value}"')

top_level_insert_at = next(
    (index for index, line in enumerate(normalized) if line.startswith("[")),
    len(normalized),
)
normalized.insert(top_level_insert_at, f'local_llm_console_provider = "{provider}"')

new_text = "\n".join(normalized).rstrip() + "\n"
if new_text != text:
    path.write_text(new_text, encoding="utf-8")
PY
}

normalize_local_llm_console_config

LOCAL_PROVIDER="$(
  python3 - "$CONFIG_PATH" <<'PY'
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8") if path.is_file() else ""


def read_string(key, default=""):
    match = re.search(rf'(?m)^\s*{re.escape(key)}\s*=\s*"([^"]*)"', text)
    return match.group(1) if match else default


def clean_string(value, default=""):
    if not isinstance(value, str):
        return default
    value = value.strip()
    return value or default


def clean_identifier(value, default):
    value = clean_string(value, default)
    allowed = set("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789._:-")
    return value if value and set(value) <= allowed else default

provider = clean_identifier(
    read_string("local_llm_console_provider")
    or read_string("model_provider")
    or read_string("oss_provider"),
    "codex",
)
print(provider)
PY
)"
LOCAL_PROVIDER="${LOCAL_PROVIDER:-codex}"

if [[ ! -x "$CODEX_HELPER" ]]; then
    echo "Local LLM Console Codex helper not found at $CODEX_HELPER" >&2
    exit 1
fi

if [[ "${1:-}" == "app-server" ]]; then
    shift
    exec "$CODEX_HELPER" \
      app-server \
      --disable plugins \
      "$@"
fi

exec "$CODEX_HELPER" \
  --disable plugins \
  "$@"
